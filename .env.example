# ============================================================
# NetDiagram — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Security (REQUIRED in production) ----
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-a-long-random-string-in-production

# ---- Application ----
APP_NAME=NetDiagram
APP_ENV=development   # development | production

# ---- Database ----
DATABASE_URL=sqlite:///./netdiagram.db
# For PostgreSQL (production recommended):
# DATABASE_URL=postgresql://user:password@localhost:5432/netdiagram

# ---- First Admin (only used if no admin exists in DB) ----
FIRST_ADMIN_USER=admin
FIRST_ADMIN_PASSWORD=change-me-in-production

# ---- Token Expiry ----
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Frontend URL (used in email links) ----
FRONTEND_URL=http://localhost:5173

# ---- SMTP (optional — email features disabled if smtp_host is empty) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_TLS=true

# ---- Rate Limiting ----
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=60
REGISTER_RATE_LIMIT=5
REGISTER_RATE_WINDOW=300
